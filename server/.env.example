# ===============================
# Server
# ===============================
PORT=5000

# כתובת האתר (React) — פרודקשן
CLIENT_URL=https://batmelechclientstatic.onrender.com

# CORS: רשימה מופרדת בפסיקים (כולל localhost לפיתוח)
CORS_ORIGINS=http://localhost:3000,https://batmelechclientstatic.onrender.com

# מפתח הצפנה (AES-256) — חובה ב-production
# ליצירת מפתח חדש: node -e "console.log(require('./utils/encryption').generateEncryptionKey())"
ENCRYPTION_KEY=your-base64-encryption-key-here

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/seminaryProjectDB
# DB_FAIL_FAST=true

# ===============================
# SMTP (Nodemailer) — שליחת מיילים
# ===============================
# חובה קובץ server/.env (לא רק .env.example!)
# בלי הגדרות אלה — מיילים יודפסו לקונסול בלבד.
#
# Gmail:
#   1. הפעילי אימות דו-שלבי בחשבון Google
#   2. צרי "סיסמת אפליקציה": https://myaccount.google.com/apppasswords
#   3. מלאי SMTP_USER = המייל שלך, SMTP_PASS = סיסמת האפליקציה (16 תווים)
#   4. MAIL_FROM = אותו מייל כמו SMTP_USER
#
# בדיקה: node scripts/test-smtp.js your@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=your@gmail.com
MAIL_FROM_NAME=מדרשיות

# תוקף קישור איפוס סיסמה (שעות)
PASSWORD_RESET_EXPIRES_HOURS=1

# דוגמאות נפוצות:
# Gmail (App Password): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<API_KEY>
